<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - POS System</title>
    <link rel="stylesheet" href="/static/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="/static/js/ui.js"></script>
    <style>
        /* ===== Table styling (matches reports page) ===== */
        .report-table-scroll { max-height: 420px; overflow-y: auto; border-radius: 6px; border: 1px solid #e9ecef; }
        .report-table-scroll table { border-collapse: collapse; width: 100%; font-size: 0.9rem; }
        .report-table-scroll thead th {
            position: sticky; top: 0; z-index: 2;
            background: #2c3e50; color: white;
            padding: 0.65rem 1rem; text-align: left;
            font-weight: 600; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.03em;
            border-bottom: 2px solid #1a252f;
        }
        .report-table-scroll tbody tr:nth-child(even) { background: #f8f9fa; }
        .report-table-scroll tbody tr:hover { background: #e8f4fd; transition: background 0.12s; }
        .report-table-scroll tbody td { padding: 0.6rem 1rem; border-bottom: 1px solid #edf0f2; vertical-align: middle; }
        .report-table-scroll tbody tr:last-child td { border-bottom: none; }

        /* ===== Section header accents ===== */
        .card h2 {
            display: flex; align-items: center; gap: 0.5rem;
            padding-left: 0.75rem;
            border-left: 4px solid #3498db;
            margin-bottom: 1.25rem;
            font-size: 1.05rem;
            color: #2c3e50;
        }

        /* ===== Stat card hover lift (link cards) ===== */
        a.stat-card { transition: transform 0.15s, box-shadow 0.15s; }
        a.stat-card:hover { transform: translateY(-3px); box-shadow: 0 6px 18px rgba(52,152,219,0.2); }

        /* ===== Low stock banner ===== */
        #low-stock-banner {
            display: none; align-items: center; gap: 0.75rem;
            background: #fff8e1; border: 1px solid #ffe082; border-left: 4px solid #f39c12;
            border-radius: 8px; padding: 0.7rem 1rem; margin-bottom: 1.25rem;
            font-size: 0.9rem; color: #7f5200;
        }
        #low-stock-banner a { color: #e67e22; font-weight: 600; text-decoration: none; }
        #low-stock-banner a:hover { text-decoration: underline; }
        #low-stock-banner .banner-close { margin-left: auto; cursor: pointer; opacity: 0.45; font-size: 1rem; line-height: 1; }
        #low-stock-banner .banner-close:hover { opacity: 1; }

        /* ===== Payment method badges ===== */
        .pay-badge {
            display: inline-block; font-size: 0.7rem; font-weight: 700;
            padding: 0.1rem 0.4rem; border-radius: 10px; vertical-align: middle;
            text-transform: uppercase; letter-spacing: 0.04em;
        }
        .pay-badge.cash   { background: #d4edda; color: #155724; }
        .pay-badge.credit { background: #fff3cd; color: #856404; }
        .pay-badge.card   { background: #cce5ff; color: #004085; }
        .pay-badge.other  { background: #e9ecef; color: #495057; }
    </style>
</head>
<body class="has-sidebar">
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-brand">
                <div class="navbar-brand-icon">🛒</div>
                <span class="sidebar-brand-name" id="shop-name-title">POS System</span>
            </div>
        </div>
        <div class="sidebar-nav">
            <div class="sidebar-section-title">Overview</div>
            <a href="/" class="sidebar-item active"><span class="sidebar-icon">&#128202;</span><span class="sidebar-label">Dashboard</span></a>
            <a href="/pos" class="sidebar-item"><span class="sidebar-icon">&#128722;</span><span class="sidebar-label">Point of Sale</span></a>
            <div class="sidebar-divider"></div>
            <div class="sidebar-section-title">Sales</div>
            <a href="/sales" class="sidebar-item"><span class="sidebar-icon">&#128203;</span><span class="sidebar-label">Sales History</span></a>
            <a href="/reports" class="sidebar-item"><span class="sidebar-icon">&#128200;</span><span class="sidebar-label">Reports</span></a>
            <div class="sidebar-divider admin-only"></div>
            <div class="sidebar-section-title admin-only">Inventory</div>
            <a href="/products" class="sidebar-item admin-only"><span class="sidebar-icon">&#128230;</span><span class="sidebar-label">Products</span></a>
            <a href="/suppliers" class="sidebar-item admin-only"><span class="sidebar-icon">&#127981;</span><span class="sidebar-label">Suppliers</span></a>
            <a href="/purchase-orders" class="sidebar-item admin-only"><span class="sidebar-icon">&#128204;</span><span class="sidebar-label">Purchase Orders</span></a>
            <div class="sidebar-divider admin-only"></div>
            <div class="sidebar-section-title admin-only">Customers</div>
            <a href="/customers" class="sidebar-item admin-only"><span class="sidebar-icon">&#128101;</span><span class="sidebar-label">Customers</span></a>
            <div class="sidebar-divider admin-only"></div>
            <div class="sidebar-section-title admin-only">Finance</div>
            <a href="/expenses" class="sidebar-item admin-only"><span class="sidebar-icon">&#128176;</span><span class="sidebar-label">Expenses</span></a>
            <div class="sidebar-divider admin-only"></div>
            <div class="sidebar-section-title admin-only">Administration</div>
            <a href="/users" class="sidebar-item admin-only"><span class="sidebar-icon">&#128100;</span><span class="sidebar-label">Users</span></a>
            <a href="/settings" class="sidebar-item admin-only"><span class="sidebar-icon">&#9881;&#65039;</span><span class="sidebar-label">Settings</span></a>
            <a href="/shops" class="sidebar-item super-admin-only" style="display:none;"><span class="sidebar-icon">&#127978;</span><span class="sidebar-label">Shops</span></a>
        </div>
    </aside>
    <div class="sidebar-overlay" id="sidebar-overlay" onclick="closeSidebar()"></div>
    <div class="main-wrapper" id="main-wrapper">
        <header class="topbar">
            <button class="topbar-toggle" onclick="toggleSidebar()" title="Toggle sidebar">&#9776;</button>
            <div id="shop-switcher" class="shop-switcher" style="display:none;">
                <select id="shop-select" onchange="switchShop(this.value)">
                    <option value="">&#127760; All Shops</option>
                </select>
            </div>
            <div class="topbar-spacer"></div>
            <div class="user-profile-container">
                <div class="user-profile" id="user-profile-toggle">
                    <div class="user-profile-icon" id="user-icon">A</div>
                    <div class="user-profile-info">
                        <span class="user-profile-name" id="user-name">Admin</span>
                    </div>
                    <span class="user-profile-arrow">&#9660;</span>
                </div>
                <div class="user-dropdown" id="user-dropdown">
                    <div class="dropdown-header">
                        <div class="dropdown-role">
                            Role: <span class="role-badge admin" id="role-badge">Administrator</span>
                        </div>
                    </div>
                    <div class="dropdown-menu">
                        <a href="#" onclick="openChangePasswordModal(); return false;" class="dropdown-item">Change Password</a>
                        <a href="/logout" class="dropdown-item">Logout</a>
                    </div>
                </div>
            </div>
        </header>


    <div class="container">
        <h1 style="font-size:1.35rem; font-weight:700; color:#2c3e50; margin-bottom:0.25rem;">Dashboard</h1>
        <p id="greeting" style="color: #7f8c8d; margin-bottom: 1rem; font-size: 0.95rem;"></p>

        <!-- Quick Actions Bar -->
        <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
            <a href="/pos" class="btn btn-success" style="text-decoration: none; display: inline-block;">
                🛒 New Sale
            </a>
            <a href="/products" class="btn btn-primary admin-only" style="text-decoration: none; display: inline-block;">
                + Add Product
            </a>
            <a href="/reports" class="btn btn-secondary" style="text-decoration: none; display: inline-block;">
                📊 View Reports
            </a>
        </div>

        <!-- Low Stock Banner -->
        <div id="low-stock-banner">
            <span>⚠️</span>
            <span id="low-stock-banner-text"></span>
            <a href="/products?stock=low">View Products →</a>
            <span class="banner-close" onclick="this.parentElement.style.display='none'" title="Dismiss">✕</span>
        </div>

        <!-- Key Metrics -->
        <div class="stats-grid">
            <a href="/products" class="stat-card" style="text-decoration: none; color: inherit; cursor: pointer;">
                <h3>Total Products</h3>
                <div class="value" id="total-products">0</div>
            </a>
            <a href="/products?stock=low" class="stat-card" style="text-decoration: none; color: inherit; cursor: pointer;">
                <h3>Low Stock Items</h3>
                <div class="value" style="color: #e67e22;" id="low-stock">0</div>
            </a>
            <a href="/products?stock=out" class="stat-card" style="text-decoration: none; color: inherit; cursor: pointer;">
                <h3>Out of Stock</h3>
                <div class="value" style="color: #e74c3c;" id="out-of-stock">0</div>
            </a>
            <div class="stat-card">
                <h3>Today's Sales</h3>
                <div class="value" id="today-sales">$0.00</div>
            </div>
            <div class="stat-card admin-only">
                <h3>Today's Profit</h3>
                <div class="value" style="color: #27ae60;" id="today-profit">$0.00</div>
            </div>
            <div class="stat-card">
                <h3>Transactions Today</h3>
                <div class="value" id="today-count">0</div>
            </div>
            <div class="stat-card">
                <h3>Avg Transaction</h3>
                <div class="value" style="color: #3498db;" id="avg-transaction">$0.00</div>
            </div>
            <div class="stat-card">
                <h3>Discounts Today</h3>
                <div class="value" style="color: #f39c12;" id="total-discount">$0.00</div>
            </div>
        </div>

        <!-- Cash Flow Overview (Admin Only) -->
        <div class="card admin-only" style="margin-top: 1.5rem;">
            <h2>💰 Cash Flow Overview</h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
                <div style="background: #eafaf1; padding: 1rem; border-radius: 8px; border-left: 4px solid #27ae60;">
                    <div style="font-size: 0.85rem; color: #7f8c8d; margin-bottom: 0.3rem;">Cash Collected Today</div>
                    <div style="font-size: 1.4rem; font-weight: bold; color: #27ae60;" id="cash-collected-today">$0.00</div>
                </div>
                <div style="background: #fef9e7; padding: 1rem; border-radius: 8px; border-left: 4px solid #f39c12;">
                    <div style="font-size: 0.85rem; color: #7f8c8d; margin-bottom: 0.3rem;">Credit Sales Today</div>
                    <div style="font-size: 1.4rem; font-weight: bold; color: #f39c12;" id="credit-sales-today">$0.00</div>
                </div>
                <div style="background: #fdedec; padding: 1rem; border-radius: 8px; border-left: 4px solid #e74c3c;">
                    <div style="font-size: 0.85rem; color: #7f8c8d; margin-bottom: 0.3rem;">Total Outstanding</div>
                    <div style="font-size: 1.4rem; font-weight: bold; color: #e74c3c;" id="total-outstanding">$0.00</div>
                </div>
                <div style="background: #f4ecf7; padding: 1rem; border-radius: 8px; border-left: 4px solid #8e44ad;">
                    <div style="font-size: 0.85rem; color: #7f8c8d; margin-bottom: 0.3rem;">Overdue</div>
                    <div style="font-size: 1.4rem; font-weight: bold; color: #8e44ad;" id="overdue-amount">$0.00</div>
                    <div style="font-size: 0.8rem; color: #7f8c8d;" id="overdue-count"></div>
                </div>
            </div>
        </div>

        <!-- Today vs Yesterday Comparison -->
        <div class="card">
            <h2 style="margin-bottom: 1rem;">📈 Today vs Yesterday</h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
                <div style="background: #f8f9fa; padding: 1rem; border-radius: 6px;">
                    <div style="font-size: 0.9rem; color: #7f8c8d; margin-bottom: 0.5rem;">Sales</div>
                    <div style="font-size: 1.3rem; font-weight: bold;" id="sales-comparison">-</div>
                    <div style="font-size: 0.85rem; margin-top: 0.3rem;" id="sales-change">-</div>
                </div>
                <div style="background: #f8f9fa; padding: 1rem; border-radius: 6px;">
                    <div style="font-size: 0.9rem; color: #7f8c8d; margin-bottom: 0.5rem;">Transactions</div>
                    <div style="font-size: 1.3rem; font-weight: bold;" id="transactions-comparison">-</div>
                    <div style="font-size: 0.85rem; margin-top: 0.3rem;" id="transactions-change">-</div>
                </div>
                <div class="admin-only" style="background: #f8f9fa; padding: 1rem; border-radius: 6px;">
                    <div style="font-size: 0.9rem; color: #7f8c8d; margin-bottom: 0.5rem;">Profit</div>
                    <div style="font-size: 1.3rem; font-weight: bold;" id="profit-comparison">-</div>
                    <div style="font-size: 0.85rem; margin-top: 0.3rem;" id="profit-change">-</div>
                </div>
            </div>
        </div>

        <!-- Sales Trend Chart -->
        <div class="card">
            <h2 style="margin-bottom: 1rem;">📊 7-Day Sales Trend</h2>
            <canvas id="salesTrendChart" style="max-height: 300px;"></canvas>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 1.5rem;">
            <!-- Best Selling Products -->
            <div class="card">
                <h2 style="margin-bottom: 1rem;">🏆 Best Sellers (Last 7 Days)</h2>
                <div id="best-sellers-list">
                    <p style="text-align: center; color: #7f8c8d; padding: 2rem;">Loading...</p>
                </div>
            </div>

            <!-- Recent Sales Activity -->
            <div class="card">
                <h2 style="margin-bottom: 1rem;">💰 Recent Sales</h2>
                <div id="recent-sales-list">
                    <p style="text-align: center; color: #7f8c8d; padding: 2rem;">Loading...</p>
                </div>
            </div>
        </div>

        <!-- Stock Activity (Admin Only) -->
        <div class="card admin-only">
            <h2>Recent Stock Activity</h2>
            <div class="report-table-scroll">
            <table>
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Action</th>
                        <th>Quantity</th>
                        <th>Note</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody id="stock-history">
                    <tr>
                        <td colspan="5" style="text-align: center;">Loading...</td>
                    </tr>
                </tbody>
            </table>
            </div>
        </div>
    </div>

    <!-- Change Password Modal -->
    <div id="change-password-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Change Password</h2>
                <button class="close-btn" onclick="closeChangePasswordModal()">&times;</button>
            </div>
            <form id="change-password-form">
                <div class="form-group">
                    <label>Current Password *</label>
                    <input type="password" id="current-password" required placeholder="Enter current password">
                </div>
                <div class="form-group">
                    <label>New Password *</label>
                    <input type="password" id="new-password" required placeholder="Minimum 6 characters" minlength="6">
                </div>
                <div class="form-group">
                    <label>Confirm New Password *</label>
                    <input type="password" id="confirm-password" required placeholder="Re-enter new password" minlength="6">
                </div>
                <div style="display: flex; gap: 1rem;">
                    <button type="submit" class="btn btn-primary">Change Password</button>
                    <button type="button" class="btn btn-secondary" onclick="closeChangePasswordModal()">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        let currencySymbol = '$'; // Default, will be updated from API

        // Load dashboard stats
        let salesChart = null;

        async function loadDashboardStats() {
            try {
                const response = await fetch('/api/dashboard-stats');
                const stats = await response.json();

                // Update basic stats
                document.getElementById('total-products').textContent = stats.total_products;
                document.getElementById('low-stock').textContent = stats.low_stock_items;

                // Show low stock warning banner
                if (stats.low_stock_items > 0) {
                    const n = stats.low_stock_items;
                    document.getElementById('low-stock-banner-text').textContent =
                        `${n} item${n > 1 ? 's are' : ' is'} running low on stock.`;
                    document.getElementById('low-stock-banner').style.display = 'flex';
                }

                document.getElementById('today-sales').textContent = `${currencySymbol}${stats.today_sales.toFixed(2)}`;
                document.getElementById('today-count').textContent = stats.today_sales_count;
                document.getElementById('out-of-stock').textContent = stats.out_of_stock_items || 0;
                document.getElementById('avg-transaction').textContent = `${currencySymbol}${stats.avg_transaction.toFixed(2)}`;
                document.getElementById('total-discount').textContent = `${currencySymbol}${stats.total_discount_today.toFixed(2)}`;

                if (stats.today_profit !== undefined) {
                    document.getElementById('today-profit').textContent = `${currencySymbol}${stats.today_profit.toFixed(2)}`;
                }

                // Update cash flow cards (admin only)
                if (stats.cash_flow) {
                    document.getElementById('cash-collected-today').textContent = `${currencySymbol}${stats.cash_flow.cash_collected_today.toFixed(2)}`;
                    document.getElementById('credit-sales-today').textContent = `${currencySymbol}${stats.cash_flow.credit_sales_today.toFixed(2)}`;
                    document.getElementById('total-outstanding').textContent = `${currencySymbol}${stats.cash_flow.total_outstanding.toFixed(2)}`;
                    document.getElementById('overdue-amount').textContent = `${currencySymbol}${stats.cash_flow.overdue_amount.toFixed(2)}`;
                    document.getElementById('overdue-count').textContent = stats.cash_flow.overdue_count > 0 ? `${stats.cash_flow.overdue_count} invoice(s)` : '';
                }

                // Update comparison cards
                updateComparison(stats);

                // Update sales trend chart
                updateSalesTrendChart(stats.sales_trend);

                // Update best sellers
                updateBestSellers(stats.best_sellers);

                // Update recent sales
                updateRecentSales(stats.recent_sales);

            } catch (error) {
                console.error('Error loading stats:', error);
            }
        }

        function updateComparison(stats) {
            // Sales comparison
            const salesChange = stats.today_sales - stats.yesterday_sales;
            const salesPercent = stats.yesterday_sales > 0
                ? ((salesChange / stats.yesterday_sales) * 100).toFixed(1)
                : 0;
            document.getElementById('sales-comparison').innerHTML =
                `<span>Today: ${currencySymbol}${stats.today_sales.toFixed(2)}</span><br><span style="font-size:0.85rem; color:#7f8c8d;">Yesterday: ${currencySymbol}${stats.yesterday_sales.toFixed(2)}</span>`;
            document.getElementById('sales-change').innerHTML =
                salesChange >= 0
                ? `<span style="color: #27ae60;">↑ ${currencySymbol}${Math.abs(salesChange).toFixed(2)} (${Math.abs(salesPercent)}%)</span>`
                : `<span style="color: #e74c3c;">↓ ${currencySymbol}${Math.abs(salesChange).toFixed(2)} (${Math.abs(salesPercent)}%)</span>`;

            // Transactions comparison
            const transChange = stats.today_sales_count - stats.yesterday_count;
            const transPercent = stats.yesterday_count > 0
                ? ((transChange / stats.yesterday_count) * 100).toFixed(1)
                : 0;
            document.getElementById('transactions-comparison').innerHTML =
                `<span>Today: ${stats.today_sales_count}</span><br><span style="font-size:0.85rem; color:#7f8c8d;">Yesterday: ${stats.yesterday_count}</span>`;
            document.getElementById('transactions-change').innerHTML =
                transChange >= 0
                ? `<span style="color: #27ae60;">↑ ${transChange} (${Math.abs(transPercent)}%)</span>`
                : `<span style="color: #e74c3c;">↓ ${Math.abs(transChange)} (${Math.abs(transPercent)}%)</span>`;

            // Profit comparison (admin only)
            if (stats.today_profit !== undefined) {
                const profitChange = stats.today_profit - stats.yesterday_profit;
                const profitPercent = stats.yesterday_profit > 0
                    ? ((profitChange / stats.yesterday_profit) * 100).toFixed(1)
                    : 0;
                document.getElementById('profit-comparison').innerHTML =
                    `<span>Today: ${currencySymbol}${stats.today_profit.toFixed(2)}</span><br><span style="font-size:0.85rem; color:#7f8c8d;">Yesterday: ${currencySymbol}${stats.yesterday_profit.toFixed(2)}</span>`;
                document.getElementById('profit-change').innerHTML =
                    profitChange >= 0
                    ? `<span style="color: #27ae60;">↑ ${currencySymbol}${Math.abs(profitChange).toFixed(2)} (${Math.abs(profitPercent)}%)</span>`
                    : `<span style="color: #e74c3c;">↓ ${currencySymbol}${Math.abs(profitChange).toFixed(2)} (${Math.abs(profitPercent)}%)</span>`;
            }
        }

        function updateSalesTrendChart(trendData) {
            const ctx = document.getElementById('salesTrendChart').getContext('2d');
            const gradient = ctx.createLinearGradient(0, 0, 0, 280);
            gradient.addColorStop(0, 'rgba(52, 152, 219, 0.35)');
            gradient.addColorStop(1, 'rgba(52, 152, 219, 0)');

            // Fill in missing days with 0
            const last7Days = [];
            const salesData = [];
            for (let i = 6; i >= 0; i--) {
                const date = new Date();
                date.setDate(date.getDate() - i);
                const dateStr = date.toISOString().split('T')[0];
                last7Days.push(dateStr);

                const dayData = trendData.find(d => d.date === dateStr);
                salesData.push(dayData ? dayData.total_sales : 0);
            }

            const labels = last7Days.map(d => {
                const date = new Date(d);
                return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
            });

            if (salesChart) {
                salesChart.destroy();
            }

            salesChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Sales',
                        data: salesData,
                        borderColor: '#3498db',
                        backgroundColor: gradient,
                        tension: 0.4,
                        pointBackgroundColor: '#3498db',
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function(ctx) {
                                    return ' ' + currencySymbol + ctx.parsed.y.toFixed(2);
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: 'rgba(0,0,0,0.05)' },
                            ticks: {
                                callback: function(value) {
                                    return currencySymbol + value;
                                }
                            }
                        },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        function updateBestSellers(bestSellers) {
            const container = document.getElementById('best-sellers-list');

            if (bestSellers.length === 0) {
                container.innerHTML = '<p style="text-align: center; color: #7f8c8d; padding: 2rem;">No sales data yet</p>';
                return;
            }

            const medals = ['🥇', '🥈', '🥉'];
            const maxSold = bestSellers[0].total_sold || 1;

            container.innerHTML = bestSellers.map((product, index) => {
                const rankLabel = index < 3
                    ? `<span style="font-size:1.1rem;">${medals[index]}</span>`
                    : `<span style="display:inline-flex;align-items:center;justify-content:center;width:1.4rem;height:1.4rem;background:#e9ecef;border-radius:50%;font-size:0.75rem;font-weight:700;color:#6c757d;">${index + 1}</span>`;
                const barPct = Math.round((product.total_sold / maxSold) * 100);
                return `
                <div style="padding: 0.7rem 0.75rem; background: ${index % 2 === 0 ? '#f8f9fa' : 'white'}; border-radius: 6px; margin-bottom: 0.4rem;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.35rem;">
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            ${rankLabel}
                            <div>
                                <div style="font-weight: 600; font-size: 0.9rem;">${product.name}</div>
                                <div style="font-size: 0.78rem; color: #7f8c8d;">${product.sku || 'N/A'} &middot; ${currencySymbol}${product.price.toFixed(2)} each</div>
                            </div>
                        </div>
                        <div style="font-weight: bold; color: #3498db; white-space: nowrap;">${product.total_sold} sold</div>
                    </div>
                    <div style="height: 4px; background: #e9ecef; border-radius: 2px; overflow: hidden;">
                        <div style="height: 100%; width: ${barPct}%; background: ${index === 0 ? '#f1c40f' : index === 1 ? '#95a5a6' : index === 2 ? '#cd7f32' : '#3498db'}; border-radius: 2px; transition: width 0.4s;"></div>
                    </div>
                </div>`;
            }).join('');
        }

        function updateRecentSales(recentSales) {
            const container = document.getElementById('recent-sales-list');

            if (recentSales.length === 0) {
                container.innerHTML = '<p style="text-align: center; color: #7f8c8d; padding: 2rem;">No recent sales</p>';
                return;
            }

            container.innerHTML = recentSales.map(sale => {
                const date = parseUTC(sale.sale_date);
                const timeAgo = getTimeAgo(date);
                const hasDiscount = sale.discount_amount > 0;
                const pm = (sale.payment_method || '').toLowerCase();
                const pmBadge = pm ? `<span class="pay-badge ${['cash','credit','card'].includes(pm) ? pm : 'other'}">${pm || 'sale'}</span> ` : '';

                return `
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.7rem 0.75rem; border-bottom: 1px solid #ecf0f1;">
                        <div>
                            <div style="font-weight: 600;">${pmBadge}#${sale.id}</div>
                            <div style="font-size: 0.82rem; color: #7f8c8d;">
                                ${sale.username || 'N/A'} &middot; ${timeAgo}
                            </div>
                        </div>
                        <div style="text-align: right;">
                            <div style="font-weight: bold; color: #27ae60;">${currencySymbol}${sale.total_amount.toFixed(2)}</div>
                            ${hasDiscount ? `<div style="font-size: 0.8rem; color: #f39c12;">-${currencySymbol}${sale.discount_amount.toFixed(2)} disc.</div>` : ''}
                        </div>
                    </div>
                `;
            }).join('');
        }

        function getTimeAgo(date) {
            const seconds = Math.floor((new Date() - date) / 1000);
            if (seconds < 60) return 'Just now';
            if (seconds < 3600) return Math.floor(seconds / 60) + 'm ago';
            if (seconds < 86400) return Math.floor(seconds / 3600) + 'h ago';
            return Math.floor(seconds / 86400) + 'd ago';
        }

        // Load user info
        async function loadUserInfo() {
            try {
                const response = await fetch('/api/current-user');
                const user = await response.json();

                // Set shop name
                if (user.shop_name) {
                    document.getElementById('shop-name-title').textContent = user.shop_name;
                }
                if (user.shop_icon) {
                    const bi = document.querySelector('.navbar-brand-icon');
                    if (bi) bi.textContent = user.shop_icon;
                }

                // Set currency symbol
                if (user.currency) {
                    currencySymbol = user.currency;
                }

                // Set user icon (first letter of name)
                const initial = (user.full_name || user.username).charAt(0).toUpperCase();
                document.getElementById('user-icon').textContent = initial;

                // Set user name
                document.getElementById('user-name').textContent = user.full_name || user.username;

                // Set user role badge
                const roleBadge = document.getElementById('role-badge');
                roleBadge.textContent = getRoleLabel(user.role);
                roleBadge.className = getRoleBadgeClass(user.role);

                // Show/hide admin-only elements
                const adminElements = document.querySelectorAll('.admin-only');
                if (isAdminRole(user.role)) {
                    adminElements.forEach(el => el.style.display = '');
                } else {
                    adminElements.forEach(el => el.style.display = 'none');
                }

                // Show super_admin only elements and shop switcher
                if (user.role === 'super_admin') {
                    document.querySelectorAll('.super-admin-only').forEach(el => el.style.display = '');
                    await loadShopSwitcher(user.active_shop_id);
                } else if (user.role === 'shop_owner') {
                    await loadShopSwitcher(user.active_shop_id);
                }
            } catch (error) {
                console.error('Error loading user info:', error);
            }
        }

        async function loadShopSwitcher(activeShopId) {
            try {
                const resp = await fetch('/api/shops');
                const shops = await resp.json();
                const switcher = document.getElementById('shop-switcher');
                const sel = document.getElementById('shop-select');
                sel.innerHTML = '<option value="">All Shops</option>';
                shops.forEach(s => {
                    const opt = document.createElement('option');
                    opt.value = s.id;
                    opt.textContent = (s.icon || '🛒') + ' ' + s.name;
                    if (activeShopId && String(s.id) === String(activeShopId)) opt.selected = true;
                    sel.appendChild(opt);
                });
                if (!activeShopId) sel.value = '';
                switcher.style.display = '';
            } catch (e) { console.error('Failed to load shops', e); }
        }

        async function switchShop(shopId) {
            try {
                await fetch('/api/shops/switch', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({shop_id: shopId || null})
                });
                window.location.reload();
            } catch (e) { console.error('Failed to switch shop', e); }
        }

        // Toggle user dropdown
        document.getElementById('user-profile-toggle').addEventListener('click', function(e) {
            e.stopPropagation();
            this.classList.toggle('active');
            document.getElementById('user-dropdown').classList.toggle('active');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            const dropdown = document.getElementById('user-dropdown');
            const toggle = document.getElementById('user-profile-toggle');
            if (!toggle.contains(e.target) && !dropdown.contains(e.target)) {
                toggle.classList.remove('active');
                dropdown.classList.remove('active');
            }
        });

        // Load recent stock history
        async function loadStockHistory() {
            try {
                const response = await fetch('/api/stock-history');
                const history = await response.json();

                const tbody = document.getElementById('stock-history');
                if (history.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" style="text-align: center;">No stock activity yet</td></tr>';
                    return;
                }

                tbody.innerHTML = history.slice(0, 10).map(item => `
                    <tr>
                        <td>${item.product_name}</td>
                        <td><span style="text-transform: capitalize;">${item.action_type}</span></td>
                        <td>${item.quantity_change > 0 ? '+' : ''}${item.quantity_change}</td>
                        <td>${item.note || '-'}</td>
                        <td>${parseUTC(item.created_at).toLocaleString()}</td>
                    </tr>
                `).join('');
            } catch (error) {
                console.error('Error loading stock history:', error);
            }
        }

        // Change password modal
        function openChangePasswordModal() {
            document.getElementById('change-password-modal').classList.add('active');
            document.getElementById('user-dropdown').classList.remove('active');
            document.getElementById('user-profile-toggle').classList.remove('active');
        }

        function closeChangePasswordModal() {
            document.getElementById('change-password-modal').classList.remove('active');
            document.getElementById('change-password-form').reset();
        }

        // Handle password change
        document.getElementById('change-password-form').addEventListener('submit', async (e) => {
            e.preventDefault();

            const currentPassword = document.getElementById('current-password').value;
            const newPassword = document.getElementById('new-password').value;
            const confirmPassword = document.getElementById('confirm-password').value;

            // Validate passwords match
            if (newPassword !== confirmPassword) {
                showToast('New passwords do not match!', 'warning');
                return;
            }

            // Validate password length
            if (newPassword.length < 6) {
                showToast('New password must be at least 6 characters!', 'warning');
                return;
            }

            try {
                const response = await fetch('/api/change-password', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        current_password: currentPassword,
                        new_password: newPassword
                    })
                });

                const result = await response.json();

                if (response.ok) {
                    showToast('Password changed successfully!', 'success');
                    closeChangePasswordModal();
                } else {
                    showToast(result.error || 'Error changing password', 'error');
                }
            } catch (error) {
                console.error('Error changing password:', error);
                showToast('Error changing password', 'error');
            }
        });

        // Greeting
        function setGreeting() {
            const hour = new Date().getHours();
            let greeting = 'Good evening';
            if (hour < 12) greeting = 'Good morning';
            else if (hour < 17) greeting = 'Good afternoon';
            document.getElementById('greeting').textContent = `${greeting}! Here's your store overview.`;
        }

        // Initialize
        setGreeting();
        loadUserInfo();
        loadDashboardStats();
        loadStockHistory();
    </script>
    <script src="/static/js/session.js"></script>
    </div><!-- /main-wrapper -->
</body>
</html>
