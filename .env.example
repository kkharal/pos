# MySQL Database Credentials
# Copy to .env file and update with your MySQL server details

# Database Type
DB_TYPE=mysql

# MySQL Server Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pos_mysql_app

# Flask Configuration
# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
SESSION_TIMEOUT=1800

# Production settings (do NOT set FLASK_DEBUG=1 in production)
FLASK_DEBUG=0
HOST=127.0.0.1
PORT=8080

# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=https://yourdomain.com

# Multi-Shop Settings
ENABLE_MULTI_SHOP=true
DEFAULT_SHOP_ID=1
