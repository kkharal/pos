# MySQL Database Credentials
# Copy to .env file and update with your MySQL server details

# Database Type
DB_TYPE=mysql

# MySQL Server Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pos_mysql_app

# Flask Configuration
SECRET_KEY=your-secret-key-change-this-in-production
SESSION_TIMEOUT=1800

# Multi-Shop Settings
ENABLE_MULTI_SHOP=true
DEFAULT_SHOP_ID=1
